(* Lexer para expresiones aritméticas - compatible con YALex *)
(* Genera tokens: NUMBER, PLUS, TIMES, LPAREN, RPAREN, WS    *)

let digit = ['0'-'9']
let ws    = [' ' '\t' '\n']+

rule tokens =
  | digit+  -> NUMBER
  | "+"     -> PLUS
  | "*"     -> TIMES
  | "("     -> LPAREN
  | ")"     -> RPAREN
  | ws      -> WS
